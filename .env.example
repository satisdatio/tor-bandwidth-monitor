# Tor Monitor Pro Configuration Example
# Copy this file to .env and customize the values

# ==========================================
# TOR CONNECTION SETTINGS
# ==========================================

# Tor control port host (usually localhost)
TOR_CONTROL_HOST=127.0.0.1

# Tor control port (default 9051)
TOR_CONTROL_PORT=9051

# Tor control password (leave empty if using cookie auth)
TOR_CONTROL_PASSWORD=

# Tor cookie file path (alternative to password auth)
TOR_COOKIE_PATH=/var/lib/tor/control_auth_cookie

# ==========================================
# APPLICATION SETTINGS
# ==========================================

# Application secret key (REQUIRED - generate a secure random string)
TOR_MONITOR_SECRET_KEY=change-this-to-a-secure-random-string-at-least-32-chars-long

# Debug mode (set to true for development)
TOR_MONITOR_DEBUG=false

# Refresh interval in seconds
REFRESH_INTERVAL=1.0

# History size for in-memory storage
HISTORY_SIZE=3600

# Enable multi-relay support
MULTI_RELAY_ENABLED=false

# Default relay name
RELAY_NAME=default

# ==========================================
# DATABASE SETTINGS
# ==========================================

# Database URL - PostgreSQL recommended for production
TOR_MONITOR_DB_URL=postgresql://toruser:torpass@localhost:5432/tormonitor

# For development/testing with SQLite:
# TOR_MONITOR_DB_URL=sqlite:///./tor_monitor.db

# Database connection pool size
TOR_MONITOR_DB_POOL_SIZE=10

# Data retention in days
TOR_MONITOR_RETENTION_DAYS=90

# ==========================================
# WEB INTERFACE SETTINGS
# ==========================================

# Web server host
WEB_HOST=0.0.0.0

# Web server port
WEB_PORT=8080

# Enable web dashboard
WEB_DASHBOARD_ENABLED=true

# Enable REST API
WEB_API_ENABLED=true

# Enable Prometheus metrics endpoint
PROMETHEUS_ENABLED=true

# Prometheus metrics port
PROMETHEUS_PORT=9090

# Enable TLS/HTTPS
WEB_TLS_ENABLED=false

# TLS certificate path (if using HTTPS)
WEB_TLS_CERT=

# TLS key path (if using HTTPS)
WEB_TLS_KEY=

# ==========================================
# ALERTING SETTINGS
# ==========================================

# Enable alerting system
ALERTS_ENABLED=true

# Email SMTP settings
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_EMAIL_FROM=alerts@yourdomain.com

# Email recipients (comma-separated)
ALERT_EMAIL_TO=admin@yourdomain.com,ops@yourdomain.com

# Slack webhook URL
ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# PagerDuty integration key
ALERT_PAGERDUTY_KEY=your-pagerduty-integration-key

# ==========================================
# SECURITY SETTINGS
# ==========================================

# Audit log path
AUDIT_LOG_PATH=./audit.log

# Audit log retention in days
AUDIT_RETENTION_DAYS=365

# Enable anomaly detection
ANOMALY_DETECTION_ENABLED=true

# Anomaly detection threshold (z-score)
ANOMALY_THRESHOLD=3.0

# JWT token expiry in minutes
TOKEN_EXPIRY_MINUTES=60

# ==========================================
# TIMEOUT SETTINGS
# ==========================================

# Tor connection timeout in seconds
TOR_TIMEOUT=5.0

# ==========================================
# OPTIONAL FEATURES
# ==========================================

# Enable LDAP authentication (requires python-ldap)
# LDAP_SERVER=ldap://localhost
# LDAP_BASE_DN=dc=example,dc=com
# LDAP_USER_DN=cn=users,{base_dn}
# LDAP_GROUP_DN=cn=groups,{base_dn}
# LDAP_ADMIN_GROUP=cn=admins,{group_dn}